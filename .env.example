# ══════════════════════════════════════════════════════════════
# Sales Insight Automator — Environment Configuration
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── AI Engine (Required) ──────────────────────────────────────
# Groq API key — sign up at https://console.groq.com (free tier available)
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# ── Email Service (Required) ─────────────────────────────────
# Resend API key — sign up at https://resend.com (free: 100 emails/day)
RESEND_API_KEY=your_resend_api_key_here

# Sender email address (must be verified in Resend, or use their default)
SENDER_EMAIL=onboarding@resend.dev

# ── Security (Optional) ──────────────────────────────────────
# Set to 'true' to require X-API-Key header on all requests
API_KEY_REQUIRED=false

# API key value (only needed if API_KEY_REQUIRED=true)
API_KEY=your_secret_api_key_here

# ── CORS (Optional) ──────────────────────────────────────────
# Comma-separated list of allowed origins (* for all)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── File Upload (Optional) ───────────────────────────────────
# Maximum file size in MB
MAX_FILE_SIZE_MB=10

# ── Frontend (Optional) ──────────────────────────────────────
# Backend API URL for the frontend (used during build)
VITE_API_URL=http://localhost:8000
